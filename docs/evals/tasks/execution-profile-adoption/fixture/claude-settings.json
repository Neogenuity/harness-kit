{
  "companyPolicy": "keep-me",
  "permissions": {
    "deny": [
      "Read(**/.env)"
    ]
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": false,
    "filesystem": {
      "denyRead": [
        "~/.company"
      ]
    },
    "network": {
      "deniedDomains": [
        "blocked.company.invalid"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "scripts/harness/hooks/session-context.sh"
          }
        ]
      }
    ]
  }
}
