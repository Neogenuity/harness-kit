{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "scripts/hooks/session-context.sh"
      }
    ],
    "afterFileEdit": [
      {
        "command": "scripts/hooks/format.sh"
      }
    ],
    "beforeReadFile": [
      {
        "command": "scripts/hooks/guard-secrets.sh"
      }
    ],
    "stop": [
      {
        "command": "scripts/hooks/guard-project-policy.sh"
      }
    ]
  }
}
