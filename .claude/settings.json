{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(shellcheck:*)",
      "Bash(bash scripts/verify.sh:*)",
      "Bash(bash scripts/check-harness.sh:*)",
      "Bash(bash scripts/sync-agent-skills.sh:*)",
      "Bash(bash scripts/hooks/test-guard-secrets.sh:*)",
      "Bash(bash scripts/hooks/test-guard-config.sh:*)",
      "Bash(bash scripts/hooks/test-format-feedback.sh:*)",
      "Bash(bash scripts/hooks/test-advise-once.sh:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./auth.json)",
      "Read(**/auth.json)",
      "Read(./credentials.json)",
      "Read(**/credentials.json)",
      "Read(./*.pem)",
      "Read(**/*.pem)",
      "Read(./id_rsa)",
      "Read(**/id_rsa)",
      "Read(./id_ed25519)",
      "Read(**/id_ed25519)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [],
    "enableWeakerNetworkIsolation": false,
    "enableWeakerNestedSandbox": false,
    "filesystem": {
      "allowWrite": []
    },
    "network": {
      "allowedDomains": [],
      "deniedDomains": [
        "*"
      ],
      "allowLocalBinding": false,
      "allowUnixSockets": [],
      "allowAllUnixSockets": false,
      "allowMachLookup": []
    },
    "credentials": {
      "files": [
        {
          "path": "~/.aws/credentials",
          "mode": "deny"
        },
        {
          "path": "~/.ssh",
          "mode": "deny"
        }
      ],
      "envVars": [
        {
          "name": "GITHUB_TOKEN",
          "mode": "deny"
        },
        {
          "name": "NPM_TOKEN",
          "mode": "deny"
        }
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/hooks/session-context.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/hooks/format.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/hooks/guard-secrets.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/hooks/guard-config.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/hooks/guard-project-policy.sh"
          }
        ]
      }
    ]
  }
}
