{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "external_directory": "deny",
        "bash": "ask",
        "webfetch": "deny",
        "websearch": "deny",
        "read": {
            "**/.env": "deny",
            "**/.env.*": "deny",
            "**/.env.example": "allow",
            "**/.env.sample": "allow",
            "**/.env.dist": "allow",
            "**/.env.testing": "allow",
            "**/auth.json": "deny",
            "**/credentials.json": "deny",
            "**/*.pem": "deny",
            "**/id_rsa": "deny",
            "**/id_ed25519": "deny"
        }
    },
    "mcp": {}
}
