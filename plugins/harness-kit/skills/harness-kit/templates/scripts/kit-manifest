# --- policy: repo-owned after init; update diffs, never replaces --------------
# (guard-secrets.sh is mechanism, not policy, since v0.21.0: its policy is
# fully externalized to SECRET_PATTERNS/SECRET_ALLOW_PATTERNS in harness.conf,
# so the script body is generic and safe to upgrade like any other mechanism.)
policy scripts/verify.sh
policy scripts/harness.conf
policy scripts/hooks/format.sh
policy scripts/hooks/guard-project-policy.sh

# --- optional-policy: authored per repo, pinned when present ------------------
optional-policy scripts/dev.sh

# --- content: authored/copied by the SKILL's init flow, never by install ------
# <path> is template-root-relative (unlike the scripts/ entries above, whose
# paths are their own repo-relative destinations); dest= names where the
# authored copy lands. Listed here so the rename map is declared data, not
# prose — install-lib and the integrity checks ignore the content layer.
content AGENTS.md.tmpl dest=AGENTS.md
content CLAUDE.md.tmpl dest=CLAUDE.md
content ci/github-actions-harness-check.yml dest=.github/workflows/harness-check.yml
content ci/github-actions-review.yml dest=.github/workflows/review.yml
content ci/github-actions-eval-cron.yml dest=.github/workflows/eval-cron.yml

# --- retired: no longer shipped; update removes pristine, untailored copies ---
# v0.20.0 split test-install.sh into the three focused suites; this entry
# closes that release's manual-`rm` migration caveat.
retired scripts/test-install.sh
# v0.22.0 adopter test descope: the kit's own conformance suites became
# maintainer-only. Pristine copies are removed on update; the kit repo's own
# root copies are deliberate ' # tailored' forks and stay.
